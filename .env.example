# ============================================================
# Template de variáveis de ambiente — Clínica de Estética
# Copie este arquivo para .env e preencha os valores reais
#   cp .env.example .env
# ============================================================

# ─── Banco de dados ──────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=TROQUE_POR_SENHA_FORTE

# ─── JWT ─────────────────────────────────────────────────────
# Gere uma chave segura com: openssl rand -hex 32
JWT_SECRET=TROQUE_POR_CHAVE_ALEATORIA_256BITS
JWT_EXPIRATION=86400000

# ─── Frontend ────────────────────────────────────────────────
# Docker Compose interno (padrão): http://backend:8080
# API com domínio público:         https://api.seudominio.com
NEXT_PUBLIC_API_URL=http://backend:8080

# ─── Portas expostas (opcionais — padrão: 8080 e 3000) ───────
BACKEND_PORT=8080
FRONTEND_PORT=3000
